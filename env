# LiveKit Cloud project config
# Get these from LiveKit Cloud -> Project -> Settings -> Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# App behavior
LIVEKIT_ROOM_PREFIX=aitutor-
TUTOR_SUBJECT=english-speaking
LOG_LEVEL=info
VOICE_PIPELINE_PROFILE=smooth

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Optional summary tuning
# These still use LiveKit Inference by default; no extra model API key is required.
SUMMARY_LLM_MODEL=openai/gpt-4.1-nano
SUMMARY_LLM_MAX_TOKENS=260
SUMMARY_LLM_TEMPERATURE=0.2
