# LiveKit Cloud project config
# Get these from LiveKit Cloud -> Project -> Settings -> Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# App behavior
LIVEKIT_ROOM_PREFIX=aitutor-
TUTOR_SUBJECT=english-speaking
LOG_LEVEL=info

# Low-latency conversation tuning
STT_MODEL=deepgram/flux-general
STT_LANGUAGE=en
STT_EAGER_EOT_THRESHOLD=0.4
STT_EOT_TIMEOUT_MS=700
LLM_MODEL=openai/gpt-4.1-nano
LLM_MAX_TOKENS=60
LLM_TEMPERATURE=0.2
PREEMPTIVE_TTS=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Tutor voice tuning
TTS_MODEL=cartesia/sonic-turbo
TTS_VOICE=f786b574-daa5-4673-aa0c-cbe3e8534c02
TTS_SPEED=normal
TTS_VOLUME=1.0
TTS_MAX_BUFFER_DELAY_MS=300
